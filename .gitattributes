# Raw-format Qt smoke-check fixtures are binary frame data; never EOL-convert.
/Tests/fixtures/raw/** binary

# Keep binary assets out of end-of-line conversion.
*.bmp binary
*.gif binary
*.ico binary
*.jpeg binary
*.jpg binary
*.png binary
*.tif binary
*.tiff binary
